namespace MyParallelZipApp
{
    class Program
    {
        static void Main(string[] args)
        {
            string folderToCompress = @"D:\Study File\degree\Sem5\TPC6323\project\dataset\unzip";
            string filepath = @"D:\Study File\degree\Sem5\TPC6323\project\dataset\two.zip";
            string tempunzip = @"D:\Study File\degree\Sem5\TPC6323\project\dataset\unzip";

            // 2. 初始化并启动总计时秒表
            Stopwatch totalStopwatch = new Stopwatch();
            totalStopwatch.Start();

            // 1. Run GPU parallel compression (Encrypts and Zips)
            //compressWithGPU(filepath, folderToCompress);

            // 2. Run GPU parallel decompression (Unzips and Decrypts)
            decompressWithGPU(filepath, tempunzip);

            // 3. 停止总计时
            totalStopwatch.Stop();

            // 4. 漂亮地打印出总用时
            Console.WriteLine("\n========================================");
            Console.WriteLine("        GPU PERFORMANCE REPORT          ");
            Console.WriteLine("========================================");
            Console.WriteLine($"Total Execution Time: {totalStopwatch.Elapsed.TotalSeconds:F4} seconds");
            Console.WriteLine($"Total Milliseconds:   {totalStopwatch.ElapsedMilliseconds} ms");
